[gd_resource type="Resource" script_class="LootTable" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/data/loot_table.gd" id="1_table"]
[ext_resource type="Script" path="res://scripts/data/loot_entry.gd" id="2_entry"]
[ext_resource type="Resource" path="res://resources/items/health_potion.tres" id="3_hp_pot"]
[ext_resource type="Resource" path="res://resources/items/sword_basic.tres" id="4_sword"]

[sub_resource type="Resource" id="LootEntry_hp"]
